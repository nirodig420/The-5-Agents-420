# ============================================
# The 5 Agents — קובץ דוגמה למשתני סביבה
# העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
# אל תעלה את .env ל-git!
# ============================================

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=

# --- OpenAI (יצירת תמונות — gpt-image-2) ---
OPENAI_API_KEY=

# --- Meta (Facebook / Instagram) — סוכן מריו ---
# ברירת המחדל היא לעבוד דרך Make (החיבור כבר קיים) — אז ה-META_* האלה נחוצים רק
# במסלול ה-API הגולמי (Phase 2 / סקיל meta-publish). ראה mario/SETUP.md.
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
META_AD_ACCOUNT_ID=

# --- Make.com (אוטומציות — שכבת הביצוע של מריו + אמציה) ---
MAKE_API_TOKEN=
MAKE_WEBHOOK_URL=

# --- Airtable (ה-CRM הראשי — סוכן אמציה) ---
# Personal Access Token: Airtable -> Developer Hub -> Personal Access Tokens. ראה amatzia-automation/SETUP.md
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# --- ManyChat (בוטים — סוכן אמציה) ---
# הפלואו נבנה בעורך; הטוקן משמש לחיבור Make/Webhook. ManyChat -> Settings -> API.
MANYCHAT_API_TOKEN=

# --- WordPress (ניהול האתר — סוכן איתן) ---
# הפק Application Password ב-wp-admin: Users -> Profile -> Application Passwords. ראה eitan/SETUP.md
WP_SITE_URL=https://nirodigital.co.il
WP_USERNAME=
WP_APP_PASSWORD=

# --- כללי ---
NODE_ENV=development
